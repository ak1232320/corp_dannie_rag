# --- OpenRouter (LLM-генерация ответа) ---
# Без ключа приложение работает в экстрактивном режиме (всегда запускается).
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# RAG_USE_LLM=auto        # auto | 1 | 0

# --- Эмбеддинги / гибридный поиск (опционально переопределить) ---
# RAG_EMB_MODEL=cointegrated/rubert-tiny2
# RAG_HYBRID_ALPHA=0.5    # вес семантики vs лексики
# RAG_USE_HYBRID=1        # 1 — гибрид, 0 — чистый TF-IDF

# --- Kaggle API (для scripts/prepare_datasets.py) ---
# Альтернатива: положить kaggle.json в %USERPROFILE%\.kaggle\kaggle.json
# KAGGLE_USERNAME=
# KAGGLE_KEY=
